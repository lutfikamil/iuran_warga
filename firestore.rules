rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // CATATAN:
    // Rules Firestore hanya bisa mengenali identitas lewat request.auth.
    // Login kustom yang hanya membaca koleksi `users` dari client tanpa
    // Firebase Auth tidak bisa dibedakan secara aman di rules.
    //
    // Karena itu rules ini difokuskan untuk:
    // 1. merapikan hak akses berbasis role jika user punya request.auth, dan
    // 2. mencakup semua koleksi yang saat ini dipakai aplikasi.

    function isLoggedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return isLoggedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             userDoc().data.role != null
        ? userDoc().data.role
        : "guest";
    }

    function getUserRole() {
      return role();
    }

    function isAdmin() {
      return getUserRole() in ['admin', 'sekretaris'];
    }

    function isKetua() {
      return getUserRole() == "ketua";
    }

    function isBendahara() {
      return getUserRole() == "bendahara";
    }

    function isPetugas() {
      return getUserRole() == "petugas";
    }

    function isWarga() {
      return getUserRole() == "warga";
    }
    
    function isPengurusMusolah() {
    	return getUserRole() == "pengurus_musolah";
    }

    function isOwner(id) {
      return isLoggedIn() && request.auth.uid == id;
    }

    function canManageWarga() {
      return isAdmin();
    }

    function canManageIuran() {
      return isAdmin();
    }

    function canManageTransaksi() {
      return getUserRole() in ['admin', 'sekretaris', 'bendahara'];
    }

    function canManageSekretaris() {
      return getUserRole() in ['admin', 'sekretaris', 'ketua'];
    }

    function canManageMusolah() {
      return isAdmin() || isPengurusMusolah();
    }

    // ===== WARGA =====
    match /warga/{wargaId} {
      allow read: if isLoggedIn();
      allow create, update, delete: if canManageWarga();
    }

    // ===== WARGA KELUAR =====
    match /warga_keluar/{wargaId} {
      allow read: if isLoggedIn();
      allow create, update, delete: if canManageWarga();
    }

    // ===== RIWAYAT WARGA =====
    match /warga_riwayat/{id} {
      allow read: if isLoggedIn();
      allow create, update, delete: if canManageWarga();
    }

    // ===== IURAN =====
    match /iuran/{iuranId} {
      allow read: if isLoggedIn();
      allow write: if canManageIuran();
    }

    // ===== TRANSAKSI =====
    match /transaksi/{id} {
      allow read: if isLoggedIn();
      allow create, update, delete: if canManageTransaksi();
    }
    
    // ===== DATA SEKRETARIS =====
    match /data_sekretaris/{id} {
      allow read: if isLoggedIn();
      allow create, update, delete: if canManageSekretaris();
    }

    // ===== USERS =====
    match /users/{id} {
      allow read: if isLoggedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isOwner(id) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // ===== SETTINGS =====
    match /settings/{id} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
 // ===== KEUANGAN MUSOLAH =====
   	match /keuangan_musolah/{id} {
    	allow read: if isLoggedIn();
      allow create, update, delete: if canManageMusolah();
    }
    
    // ===== LOGS =====
    match /logs/{id} {
      allow read: if isAdmin();
      allow create: if isLoggedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

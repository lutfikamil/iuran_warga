rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return isLoggedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             userDoc().data.role != null
        ? userDoc().data.role
        : "guest";
    }

    function getUserRole() {
      return role();
    }

    function isAdmin() {
      return getUserRole() in ['admin', 'sekertaris'];
    }

    function isKetua() {
      return getUserRole() == "ketua";
    }

    function isBendahara() {
      return getUserRole() == "bendahara";
    }

    function isPetugas() {
      return getUserRole() == "petugas";
    }

    function isWarga() {
      return getUserRole() == "warga";
    }

    function isOwner(id) {
      return isLoggedIn() && request.auth.uid == id;
    }

    // ===== WARGA =====
    match /warga/{wargaId} {
      allow read: if isLoggedIn();
      allow create, update, delete: if isAdmin();
    }

    // ===== IURAN =====
    match /iuran/{iuranId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // ===== TRANSAKSI =====
    match /transaksi/{id} {
      allow read: if isLoggedIn();
      allow create, update, delete:
        if getUserRole() in ['admin', 'sekertaris', 'bendahara'];
    }

    // ===== USERS =====
    match /users/{id} {
      allow read: if isLoggedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isOwner(id) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // ===== SETTINGS =====
    match /settings/{id} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // ===== LOGS =====
    match /logs/{id} {
      allow read: if isAdmin();
      allow create: if isLoggedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}